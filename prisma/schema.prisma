// VallaPOS data model — multi-tenant browser POS.
//
// Conventions (see docs/ARCHITECTURE.md):
//  - Money is ALWAYS integer cents (priceCents, totalCents, ...). Never floats.
//  - Tax rates are basis points (taxRateBps: 825 = 8.25%).
//  - Every tenant-owned model carries businessId, is indexed on it, and has
//    per-tenant uniqueness. All queries MUST scope by businessId (see src/lib/tenant.ts).
//  - Catalog shape: Category -> Item -> Variation -> ModifierGroup -> Modifier.
//    Price + SKU live on the Variation. Modifiers are part of the taxable base.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App runtime uses the POOLED Neon endpoint (host contains "-pooler",
  // query has pgbouncer=true) so serverless functions share a small pool of
  // Postgres connections via PgBouncer instead of each holding direct ones.
  url       = env("DATABASE_URL")
  // The Prisma CLI (migrate/db/introspect) needs a DIRECT, non-pooled
  // connection — PgBouncer's transaction pooling can't run DDL/advisory-lock
  // migrations. Only evaluated by CLI commands, never by the client at runtime,
  // so it need not be present in the Vercel runtime (see src/lib/env.ts).
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (Better Auth managed). Kept minimal here; Better Auth owns these rows.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   Membership[]
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────────

// STORE = retail/counter flow (instant checkout). RESTAURANT = dining flow
// (open tabs on tables, a floor plan, per-seat split checks). Defaults to STORE
// so existing businesses are unchanged.
enum BusinessMode {
  STORE
  RESTAURANT
}

model Business {
  id                   String       @id @default(cuid())
  name                 String
  mode                 BusinessMode @default(STORE)
  // Single configurable rate for MVP; multi-rate/tax API comes later.
  taxRateBps           Int          @default(0) // basis points; 825 = 8.25%
  taxInclusive         Boolean      @default(false)
  currency             String       @default("USD")
  // IANA timezone (e.g. "America/New_York", "America/Mexico_City",
  // "America/Sao_Paulo"). Drives Z-report day boundaries and every displayed
  // timestamp (receipts, order history) so a merchant's "today" is their local
  // day, not the server's UTC day. Defaults to US Eastern for existing rows.
  timezone             String       @default("America/New_York")
  // Single-operator ("stay unlocked") mode: when true the register does NOT
  // re-lock the terminal after each sale, so a solo owner selling from one phone
  // isn't re-authenticating before every transaction. Default OFF keeps the
  // secure shared-till behavior for multi-employee businesses. See Register.tsx.
  singleOperatorMode   Boolean      @default(false)
  // Merchant-configured QR payment (confirm-based, no PSP): the cashier shows
  // qrPayValue as a QR (a payment handle/link — PIX key, UPI id, Venmo,
  // PayPal.me, a payment-link URL), the customer scans + pays out-of-band, and
  // the sale is recorded as method=QR. qrPayLabel is the rail name shown to the
  // cashier (e.g. "PIX"). All nullable/defaulted so existing businesses are
  // untouched and QR is simply off until configured.
  qrPayEnabled         Boolean      @default(false)
  qrPayLabel           String? // e.g. "PIX", "UPI", "Venmo"
  qrPayValue           String? // the string encoded into the QR
  // Integrated payments (Stripe Connect, PAYMENTS.md §9). All nullable/defaulted
  // so existing businesses are untouched and the rail stays OFF until onboarded.
  // `country` selects the Connect account country + which local payment methods
  // are eligible (US | MX | BR at launch); ISO-3166 alpha-2, uppercased.
  country              String       @default("US")
  // The connected account id (acct_...) once onboarding starts. Null = not
  // connected. Unique so the account webhook can resolve exactly one business
  // from an acct id, and a business can never hold two connected accounts.
  stripeAccountId      String?      @unique
  // Mirrors the Accounts v2 `card_payments` capability status. Only when true may
  // the (future) QR sale rail create a charge on this account. Flipped by the
  // account webhook, never trusted from the client.
  stripeChargesEnabled Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  memberships        Membership[]
  categories         Category[]
  items              Item[]
  modifierGroups     ModifierGroup[]
  orders             Order[]
  orderCounter       OrderCounter?
  drawerSessions     CashDrawerSession[]
  timeEntries        TimeEntry[]
  rooms              FloorRoom[]
  floorTables        FloorTable[]
  payRates           PayRate[]
  payPeriods         PayPeriod[]
  payslips           Payslip[]
  payslipAdjustments PayslipAdjustment[]
}

// Per-business monotonic order-number allocator. One row per business; the
// human-friendly Order.number is assigned by atomically incrementing lastNumber
// inside the checkout transaction (UPDATE ... SET lastNumber = lastNumber + 1
// takes a row lock, so concurrent cashiers never collide on @@unique([businessId, number])).
model OrderCounter {
  businessId String   @id
  lastNumber Int      @default(0) // last number handed out; next order is lastNumber + 1
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  MANAGER
  CASHIER
}

model Membership {
  id          String      @id @default(cuid())
  // Null for PIN-only staff who have no login account; otherwise the Better Auth user.
  userId      String?
  // Display name for PIN-only staff (accountless); account members use User.name/email.
  name        String?
  businessId  String
  role        Role        @default(CASHIER)
  // Granular capability grants (see src/lib/capabilities.ts). OWNER ignores this
  // (implicitly all-access); non-owners are granted a capability iff it's listed.
  permissions String[]    @default([])
  active      Boolean     @default(true) // deactivate a member without deleting their history
  pinHash     String? // optional shared-device PIN (v1)
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
  payRate     PayRate?

  @@unique([userId, businessId])
  @@index([businessId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Time tracking (clock-in / clock-out)
// ─────────────────────────────────────────────────────────────────────────────

// One shift interval [clockInAt, clockOutAt). An OPEN entry (clockOutAt = null)
// is the member's active shift; there is at most one open entry per membership
// by construction (clockIn rejects a second open). Scoped by businessId like
// every tenant-owned model.
model TimeEntry {
  id           String     @id @default(cuid())
  businessId   String
  membershipId String
  clockInAt    DateTime   @default(now())
  clockOutAt   DateTime?
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, membershipId])
  @@index([businessId, clockInAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog: Category -> Item -> Variation -> ModifierGroup -> Modifier
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items      Item[]

  @@index([businessId])
}

enum ItemType {
  PRODUCT // has stock semantics (optional)
  SERVICE // no stock (haircut, lawn mow)
}

model Item {
  id            String              @id @default(cuid())
  businessId    String
  categoryId    String?
  name          String
  type          ItemType            @default(PRODUCT)
  trackStock    Boolean             @default(false) // inventory OFF by default
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  business      Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variations    Variation[]
  modifierLinks ItemModifierGroup[]

  @@index([businessId])
  @@index([categoryId])
}

model Variation {
  id         String  @id @default(cuid())
  businessId String
  itemId     String
  name       String  @default("Default") // Small / Medium / Large
  sku        String?
  priceCents Int // price lives here
  stock      Int? // null when not tracking stock
  sortOrder  Int     @default(0)
  item       Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([itemId])
}

model ModifierGroup {
  id         String              @id @default(cuid())
  businessId String
  name       String // "Milk", "Add-ons"
  minSelect  Int                 @default(0)
  maxSelect  Int                 @default(1) // >1 allows multiple
  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  modifiers  Modifier[]
  itemLinks  ItemModifierGroup[]

  @@index([businessId])
}

model Modifier {
  id              String        @id @default(cuid())
  businessId      String
  groupId         String
  name            String // "Oat milk", "Extra cheese"
  priceDeltaCents Int           @default(0) // added to taxable base
  sortOrder       Int           @default(0)
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([groupId])
}

// Many-to-many: which modifier groups apply to which items.
model ItemModifierGroup {
  itemId  String
  groupId String
  item    Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  group   ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([itemId, groupId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Restaurant: floor plan & tables (RESTAURANT mode only)
// ─────────────────────────────────────────────────────────────────────────────

enum TableShape {
  ROUND
  SQUARE
  RECT
}

// A section of the dining room: "Main", "Patio", "Bar". Tables live inside rooms.
model FloorRoom {
  id         String       @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tables     FloorTable[]

  @@unique([businessId, name])
  @@index([businessId])
}

// A single table on the floor. x/y/width/height are pixel coordinates in a fixed
// canvas space (the editor and the service view share the same coordinate space).
model FloorTable {
  id          String       @id @default(cuid())
  businessId  String // denormalized so the tenant guard can scope without a join
  roomId      String
  label       String // "T1", "12", "Bar-3"
  shape       TableShape   @default(SQUARE)
  x           Int          @default(0)
  y           Int          @default(0)
  width       Int          @default(80)
  height      Int          @default(80)
  seats       Int          @default(4)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  room        FloorRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments OrderTable[]

  @@index([businessId])
  @@index([roomId])
}

// Join: a tab (Order) is seated at one or more tables. More than one table for a
// single order = merged tables. A FloorTable is "occupied" iff it has a row here
// whose Order.status == OPEN.
model OrderTable {
  orderId String
  tableId String
  order   Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  table   FloorTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([orderId, tableId])
  @@index([tableId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders & payments
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  OPEN
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  QR
  MANUAL
}

enum PaymentStatus {
  PENDING
  CAPTURED
  REFUNDED
  FAILED
}

model Order {
  id            String       @id @default(cuid())
  businessId    String
  // Client-generated UUID — idempotency key for offline sync (never double-insert).
  clientUuid    String
  number        Int // human-friendly per-business sequence
  cashierId     String? // Membership.id
  customerName  String?
  status        OrderStatus  @default(OPEN)
  subtotalCents Int          @default(0)
  discountCents Int          @default(0)
  taxCents      Int          @default(0)
  tipCents      Int          @default(0)
  totalCents    Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines         OrderLine[]
  payments      Payment[]
  tables        OrderTable[] // empty for store/to-go orders; 1+ for restaurant tabs

  @@unique([businessId, clientUuid]) // idempotent offline sync
  @@unique([businessId, number])
  @@index([businessId])
  @@index([businessId, createdAt])
}

model OrderLine {
  id                 String              @id @default(cuid())
  businessId         String
  orderId            String
  variationId        String? // snapshot below survives catalog edits/deletes
  nameSnapshot       String
  unitPriceCents     Int
  quantity           Int                 @default(1)
  discountCents      Int                 @default(0)
  taxCents           Int                 @default(0)
  totalCents         Int // (unitPrice + modifiers) * qty - discount
  // Restaurant tabs: which seat ordered this line (null = shared/unassigned).
  seat               Int?
  // Restaurant split checks: the split payment that cleared this line (null =
  // unsettled). A tab Order closes to PAID once every line is settled.
  settledByPaymentId String?
  modifiers          OrderLineModifier[]
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  settledBy          Payment?            @relation("LineSettlement", fields: [settledByPaymentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([orderId])
  @@index([settledByPaymentId])
}

model OrderLineModifier {
  id              String    @id @default(cuid())
  orderLineId     String
  nameSnapshot    String
  priceDeltaCents Int       @default(0)
  orderLine       OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  @@index([orderLineId])
}

model Payment {
  id            String        @id @default(cuid())
  businessId    String
  orderId       String
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(CAPTURED)
  amountCents   Int
  tenderedCents Int? // cash given
  changeCents   Int? // change due
  // Non-sensitive card metadata only (FACTA/PCI): brand + last4, never PAN/expiry.
  cardBrand     String?
  cardLast4     String?
  processorRef  String? // Stripe payment intent id, later
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Restaurant split checks: the order lines this (split) payment settled.
  settledLines  OrderLine[]   @relation("LineSettlement")

  @@index([businessId])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cash reconciliation
// ─────────────────────────────────────────────────────────────────────────────

model CashDrawerSession {
  id                String    @id @default(cuid())
  businessId        String
  openedById        String? // Membership.id
  openingFloatCents Int       @default(0)
  expectedCents     Int? // computed at close
  countedCents      Int? // entered at close (blind count supported)
  varianceCents     Int? // counted - expected
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payroll (v1) — turns clocked hours (TimeEntry) + pay rates into reviewable,
// exportable pay runs. See docs/PAYROLL.md.
//
// HARD BOUNDARY: this system RECORDS gross / adjustments / net and EXPORTS a pay
// run (CSV). It deliberately does NOT compute statutory tax withholding, FICA,
// or filings — the business hands the export to their accountant / payroll
// provider. All money is integer cents; all rates are integers.
// ─────────────────────────────────────────────────────────────────────────────

enum PayType {
  HOURLY // paid rateCents per hour worked (from TimeEntry); overtime-eligible
  SALARY // paid a fixed annual amount, prorated to the pay period; no overtime
}

enum PayPeriodStatus {
  DRAFT // being built/edited; payslips can be (re)computed and adjusted
  FINALIZED // locked for review; no recompute (reopen to DRAFT to change)
  PAID // marked as paid out to workers
}

enum AdjustmentKind {
  ADDITION // bonus, reimbursement, tip payout — increases net
  DEDUCTION // advance repayment, employer deduction — decreases net
}

// One pay-rate configuration per worker (Membership). Editable by manage_payroll.
// Money is integer cents; the overtime multiplier is basis points (15000 = 1.5×).
model PayRate {
  id                 String     @id @default(cuid())
  businessId         String
  membershipId       String     @unique // one active rate per worker
  payType            PayType    @default(HOURLY)
  // HOURLY: pay per hour worked, in cents (e.g. 1500 = $15.00/hr).
  hourlyCents        Int        @default(0)
  // SALARY: fixed annual salary in cents (e.g. 5_200_000 = $52,000/yr), prorated
  // to the pay period by days/365.
  annualCents        Int        @default(0)
  // Overtime (HOURLY only). When otEnabled, minutes over otThresholdMinutes in a
  // workweek are paid at hourlyCents × otMultiplierBps / 10000. Null threshold /
  // multiplier fall back to the calc defaults (40h / 1.5×).
  otEnabled          Boolean    @default(true)
  otThresholdMinutes Int? // e.g. 2400 = 40h/week; null = default (2400)
  otMultiplierBps    Int? // e.g. 15000 = 1.5×; null = default (15000)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  business           Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  membership         Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// A pay run over [startDate, endDate). Payslips are computed from TimeEntry within
// the window. DRAFT → FINALIZED → PAID.
model PayPeriod {
  id          String          @id @default(cuid())
  businessId  String
  label       String? // optional human label ("Jul 1–15")
  startDate   DateTime // inclusive window start (UTC instant)
  endDate     DateTime // EXCLUSIVE window end (UTC instant)
  status      PayPeriodStatus @default(DRAFT)
  notes       String?
  finalizedAt DateTime?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payslips    Payslip[]

  @@index([businessId])
  @@index([businessId, startDate])
}

// A per-worker payslip inside a pay period. Hours + money are SNAPSHOTS captured
// at compute time (rate/name can change later without altering a finalized run).
// gross = regularPay + overtimePay (hourly) or prorated salary; net = gross +
// additions − deductions. NO tax withholding is computed (see docs/PAYROLL.md).
model Payslip {
  id               String              @id @default(cuid())
  businessId       String
  payPeriodId      String
  membershipId     String
  nameSnapshot     String // worker display name at compute time
  payType          PayType             @default(HOURLY)
  // Hours worked (from TimeEntry), split by the weekly overtime rule.
  regularMinutes   Int                 @default(0)
  overtimeMinutes  Int                 @default(0)
  openShiftCount   Int                 @default(0) // shifts still open at compute time (measured to compute instant)
  // Rate snapshots.
  hourlyCents      Int                 @default(0)
  annualCents      Int                 @default(0)
  otMultiplierBps  Int                 @default(15000)
  // Money (integer cents).
  regularPayCents  Int                 @default(0)
  overtimePayCents Int                 @default(0)
  grossCents       Int                 @default(0)
  additionsCents   Int                 @default(0) // Σ ADDITION adjustments
  deductionsCents  Int                 @default(0) // Σ DEDUCTION adjustments
  netCents         Int                 @default(0) // gross + additions − deductions
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  business         Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payPeriod        PayPeriod           @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  adjustments      PayslipAdjustment[]

  @@unique([payPeriodId, membershipId]) // one payslip per worker per period
  @@index([businessId])
  @@index([payPeriodId])
}

// A manual adjustment line on a payslip. amountCents is always POSITIVE; `kind`
// determines the sign in net (ADDITION adds, DEDUCTION subtracts).
model PayslipAdjustment {
  id          String         @id @default(cuid())
  businessId  String
  payslipId   String
  kind        AdjustmentKind
  label       String
  amountCents Int // always positive; sign comes from `kind`
  createdAt   DateTime       @default(now())
  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payslip     Payslip        @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([payslipId])
}
