// VallaPOS data model — multi-tenant browser POS.
//
// Conventions (see docs/ARCHITECTURE.md):
//  - Money is ALWAYS integer cents (priceCents, totalCents, ...). Never floats.
//  - Tax rates are basis points (taxRateBps: 825 = 8.25%).
//  - Every tenant-owned model carries businessId, is indexed on it, and has
//    per-tenant uniqueness. All queries MUST scope by businessId (see src/lib/tenant.ts).
//  - Catalog shape: Category -> Item -> Variation -> ModifierGroup -> Modifier.
//    Price + SKU live on the Variation. Modifiers are part of the taxable base.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (Better Auth managed). Kept minimal here; Better Auth owns these rows.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   Membership[]
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────────

// STORE = retail/counter flow (instant checkout). RESTAURANT = dining flow
// (open tabs on tables, a floor plan, per-seat split checks). Defaults to STORE
// so existing businesses are unchanged.
enum BusinessMode {
  STORE
  RESTAURANT
}

model Business {
  id           String       @id @default(cuid())
  name         String
  mode         BusinessMode @default(STORE)
  // Single configurable rate for MVP; multi-rate/tax API comes later.
  taxRateBps   Int          @default(0) // basis points; 825 = 8.25%
  taxInclusive Boolean      @default(false)
  currency     String       @default("USD")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships    Membership[]
  categories     Category[]
  items          Item[]
  modifierGroups ModifierGroup[]
  orders         Order[]
  orderCounter   OrderCounter?
  drawerSessions CashDrawerSession[]
  timeEntries    TimeEntry[]
  rooms          FloorRoom[]
  floorTables    FloorTable[]
}

// Per-business monotonic order-number allocator. One row per business; the
// human-friendly Order.number is assigned by atomically incrementing lastNumber
// inside the checkout transaction (UPDATE ... SET lastNumber = lastNumber + 1
// takes a row lock, so concurrent cashiers never collide on @@unique([businessId, number])).
model OrderCounter {
  businessId String   @id
  lastNumber Int      @default(0) // last number handed out; next order is lastNumber + 1
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  MANAGER
  CASHIER
}

model Membership {
  id          String      @id @default(cuid())
  userId      String
  businessId  String
  role        Role        @default(CASHIER)
  active      Boolean     @default(true) // deactivate a member without deleting their history
  pinHash     String? // optional shared-device PIN (v1)
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@unique([userId, businessId])
  @@index([businessId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Time tracking (clock-in / clock-out)
// ─────────────────────────────────────────────────────────────────────────────

// One shift interval [clockInAt, clockOutAt). An OPEN entry (clockOutAt = null)
// is the member's active shift; there is at most one open entry per membership
// by construction (clockIn rejects a second open). Scoped by businessId like
// every tenant-owned model.
model TimeEntry {
  id           String     @id @default(cuid())
  businessId   String
  membershipId String
  clockInAt    DateTime   @default(now())
  clockOutAt   DateTime?
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, membershipId])
  @@index([businessId, clockInAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog: Category -> Item -> Variation -> ModifierGroup -> Modifier
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items      Item[]

  @@index([businessId])
}

enum ItemType {
  PRODUCT // has stock semantics (optional)
  SERVICE // no stock (haircut, lawn mow)
}

model Item {
  id            String              @id @default(cuid())
  businessId    String
  categoryId    String?
  name          String
  type          ItemType            @default(PRODUCT)
  trackStock    Boolean             @default(false) // inventory OFF by default
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  business      Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variations    Variation[]
  modifierLinks ItemModifierGroup[]

  @@index([businessId])
  @@index([categoryId])
}

model Variation {
  id         String  @id @default(cuid())
  businessId String
  itemId     String
  name       String  @default("Default") // Small / Medium / Large
  sku        String?
  priceCents Int // price lives here
  stock      Int? // null when not tracking stock
  sortOrder  Int     @default(0)
  item       Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([itemId])
}

model ModifierGroup {
  id         String              @id @default(cuid())
  businessId String
  name       String // "Milk", "Add-ons"
  minSelect  Int                 @default(0)
  maxSelect  Int                 @default(1) // >1 allows multiple
  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  modifiers  Modifier[]
  itemLinks  ItemModifierGroup[]

  @@index([businessId])
}

model Modifier {
  id              String        @id @default(cuid())
  businessId      String
  groupId         String
  name            String // "Oat milk", "Extra cheese"
  priceDeltaCents Int           @default(0) // added to taxable base
  sortOrder       Int           @default(0)
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([groupId])
}

// Many-to-many: which modifier groups apply to which items.
model ItemModifierGroup {
  itemId  String
  groupId String
  item    Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  group   ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([itemId, groupId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Restaurant: floor plan & tables (RESTAURANT mode only)
// ─────────────────────────────────────────────────────────────────────────────

enum TableShape {
  ROUND
  SQUARE
  RECT
}

// A section of the dining room: "Main", "Patio", "Bar". Tables live inside rooms.
model FloorRoom {
  id         String       @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tables     FloorTable[]

  @@unique([businessId, name])
  @@index([businessId])
}

// A single table on the floor. x/y/width/height are pixel coordinates in a fixed
// canvas space (the editor and the service view share the same coordinate space).
model FloorTable {
  id          String       @id @default(cuid())
  businessId  String // denormalized so the tenant guard can scope without a join
  roomId      String
  label       String // "T1", "12", "Bar-3"
  shape       TableShape   @default(SQUARE)
  x           Int          @default(0)
  y           Int          @default(0)
  width       Int          @default(80)
  height      Int          @default(80)
  seats       Int          @default(4)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  room        FloorRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments OrderTable[]

  @@index([businessId])
  @@index([roomId])
}

// Join: a tab (Order) is seated at one or more tables. More than one table for a
// single order = merged tables. A FloorTable is "occupied" iff it has a row here
// whose Order.status == OPEN.
model OrderTable {
  orderId String
  tableId String
  order   Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  table   FloorTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([orderId, tableId])
  @@index([tableId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders & payments
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  OPEN
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  QR
  MANUAL
}

enum PaymentStatus {
  PENDING
  CAPTURED
  REFUNDED
  FAILED
}

model Order {
  id            String       @id @default(cuid())
  businessId    String
  // Client-generated UUID — idempotency key for offline sync (never double-insert).
  clientUuid    String
  number        Int // human-friendly per-business sequence
  cashierId     String? // Membership.id
  customerName  String?
  status        OrderStatus  @default(OPEN)
  subtotalCents Int          @default(0)
  discountCents Int          @default(0)
  taxCents      Int          @default(0)
  tipCents      Int          @default(0)
  totalCents    Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines         OrderLine[]
  payments      Payment[]
  tables        OrderTable[] // empty for store/to-go orders; 1+ for restaurant tabs

  @@unique([businessId, clientUuid]) // idempotent offline sync
  @@unique([businessId, number])
  @@index([businessId])
  @@index([businessId, createdAt])
}

model OrderLine {
  id                 String              @id @default(cuid())
  businessId         String
  orderId            String
  variationId        String? // snapshot below survives catalog edits/deletes
  nameSnapshot       String
  unitPriceCents     Int
  quantity           Int                 @default(1)
  discountCents      Int                 @default(0)
  taxCents           Int                 @default(0)
  totalCents         Int // (unitPrice + modifiers) * qty - discount
  // Restaurant tabs: which seat ordered this line (null = shared/unassigned).
  seat               Int?
  // Restaurant split checks: the split payment that cleared this line (null =
  // unsettled). A tab Order closes to PAID once every line is settled.
  settledByPaymentId String?
  modifiers          OrderLineModifier[]
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  settledBy          Payment?            @relation("LineSettlement", fields: [settledByPaymentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([orderId])
  @@index([settledByPaymentId])
}

model OrderLineModifier {
  id              String    @id @default(cuid())
  orderLineId     String
  nameSnapshot    String
  priceDeltaCents Int       @default(0)
  orderLine       OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  @@index([orderLineId])
}

model Payment {
  id            String        @id @default(cuid())
  businessId    String
  orderId       String
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(CAPTURED)
  amountCents   Int
  tenderedCents Int? // cash given
  changeCents   Int? // change due
  // Non-sensitive card metadata only (FACTA/PCI): brand + last4, never PAN/expiry.
  cardBrand     String?
  cardLast4     String?
  processorRef  String? // Stripe payment intent id, later
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Restaurant split checks: the order lines this (split) payment settled.
  settledLines  OrderLine[]   @relation("LineSettlement")

  @@index([businessId])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cash reconciliation
// ─────────────────────────────────────────────────────────────────────────────

model CashDrawerSession {
  id                String    @id @default(cuid())
  businessId        String
  openedById        String? // Membership.id
  openingFloatCents Int       @default(0)
  expectedCents     Int? // computed at close
  countedCents      Int? // entered at close (blind count supported)
  varianceCents     Int? // counted - expected
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}
