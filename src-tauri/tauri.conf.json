{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VallaPOS",
  "version": "0.1.0",
  "identifier": "com.vallapos.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:local",
    "beforeBuildCommand": "npm run build:local"
  },
  "app": {
    "windows": [
      {
        "title": "VallaPOS",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
