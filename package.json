{
  "name": "vallapos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "dev:local": "cross-env NEXT_PUBLIC_VALLA_EDITION=local next dev",
    "build:local": "node scripts/build-local.mjs",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.9.0",
    "@radix-ui/react-dialog": "1.1.16",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-sql": "2.4.0",
    "@tauri-apps/plugin-store": "2.4.4",
    "@upstash/redis": "1.38.0",
    "better-auth": "1.6.18",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "idb": "8.0.3",
    "lucide-react": "0.515.0",
    "next": "15.5.19",
    "next-themes": "0.4.6",
    "qrcode.react": "4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "6.14.0",
    "stripe": "22.3.0",
    "tailwind-merge": "3.6.0",
    "zod": "3.25.56",
    "zustand": "5.0.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@serwist/next": "9.5.11",
    "@tailwindcss/postcss": "4.1.8",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "22.15.30",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "cross-env": "^7.0.3",
    "eslint": "9.28.0",
    "eslint-config-next": "15.5.19",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.6.12",
    "prisma": "6.9.0",
    "serwist": "9.5.11",
    "tailwindcss": "4.1.8",
    "tsx": "4.22.4",
    "typescript": "5.8.3",
    "vitest": "4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
