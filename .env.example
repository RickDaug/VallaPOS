# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres. The app runtime MUST use the POOLED connection string (host
# contains "-pooler", query has pgbouncer=true) so serverless functions don't
# exhaust Postgres connections. Get both strings from
# https://console.neon.tech -> your project -> Connection Details (toggle
# "Connection pooling" for the pooled one).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.REGION.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection — SAME credentials, host WITHOUT "-pooler".
# Used ONLY by the Prisma CLI for migrations/seed (schema.prisma `directUrl`);
# NOT needed in the Vercel runtime. Required wherever you run `prisma migrate`
# or `npm run db:seed`.
DIRECT_URL="postgresql://user:password@ep-xxx.REGION.aws.neon.tech/dbname?sslmode=require"

# Better Auth — generate a long random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL (used by the auth client).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Optional ──────────────────────────────────────────────────────────────────
# Email receipts via Resend. The `emailReceipt` server action always renders the
# receipt to text/HTML and is tenant-scoped; it SENDS only when RESEND_API_KEY is
# set. Unset = the action returns `email_not_configured` and the UI shows a clear
# "not enabled yet" notice (the app/build work unchanged). To enable:
#   1. Create an API key at https://resend.com -> API Keys.
#   2. Set RESEND_API_KEY here and in Vercel (Production + Preview).
#   3. (Recommended for production) verify a sending domain at
#      https://resend.com -> Domains and set RECEIPT_FROM_EMAIL to an address on
#      it. If RECEIPT_FROM_EMAIL is unset, sends use Resend's onboarding sender
#      (onboarding@resend.dev), which only delivers to your own account's email.
# RESEND_API_KEY="re_..."
# RECEIPT_FROM_EMAIL="receipts@yourdomain.com"

# Upstash Redis — shared, persistent store for Better Auth's rate limiter (and a
# session cache). When BOTH are set, auth rate-limits sign-in/sign-up across all
# Vercel instances and survives cold starts; when unset, it falls back to
# per-instance in-memory limiting (fine for local dev). Create a free database at
# https://console.upstash.com -> Redis -> copy the REST URL + token, and set both
# in Vercel (Production + Preview) too.
# UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# Integrated payments (Phase 3 GROUNDWORK — default OFF). Gates the inert
# provider scaffold in src/features/payments/. There is NO live payment
# integration yet; setting this true today changes nothing because no checkout
# path imports the providers. Leave unset until a real, decision-gated payment
# rail (manual/QR/Stripe Terminal) is wired. See docs/PAYMENTS.md.
# PAYMENTS_V2_ENABLED="false"

# Stripe Connect — integrated payments onboarding (PAYMENTS.md §9, PR-A). ALL
# optional: unset = the payments feature is dormant (no "Connect" button, the
# webhook returns 503) and the app/build behave exactly as before. Multi-merchant
# Connect (each business = its own connected account); the platform takes NO cut.
# To enable (sandbox): `stripe sandbox create --email you@example.com`, claim it,
# then set the keys here + in Vercel. Use a RESTRICTED key (rk_) in production.
#   STRIPE_SECRET_KEY                  server-only secret/restricted key (rk_.../sk_...)
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY publishable key (safe on the client)
#   STRIPE_WEBHOOK_SECRET              signing secret for /api/payments/webhook
#                                      (`stripe listen --forward-to .../api/payments/webhook`)
# STRIPE_SECRET_KEY="rk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Flat SaaS subscription — OUR monetization (PAYMENTS.md §9, PR-D). SEPARATE from
# the Connect sale rail above: the Business is a Customer of VallaPOS's PLATFORM
# Stripe account (they pay us for the software). Reuses STRIPE_SECRET_KEY (platform
# account) + these two OPTIONAL vars. Unset = billing dormant (no Subscribe/Manage
# UI, /api/billing/webhook returns 503, no one is blocked). Cloud edition only.
#   STRIPE_SUBSCRIPTION_PRICE_ID          the flat $19.99/mo recurring Price (price_...)
#   STRIPE_SUBSCRIPTION_WEBHOOK_SECRET    signing secret for the SEPARATE platform
#                                         endpoint /api/billing/webhook (NOT the Connect one)
# STRIPE_SUBSCRIPTION_PRICE_ID="price_..."
# STRIPE_SUBSCRIPTION_WEBHOOK_SECRET="whsec_..."

# Enforcement gate for the subscription hard block (PAYMENTS.md §9, PR-D). DEFAULT
# OFF (unarmed). Configuring billing (above) lets owners subscribe voluntarily; this
# flag — and ONLY this flag — arms the hard block that renders <SubscriptionRequired>
# for a blocked tenant. Arm it (=true) ONLY after backfilling trials for existing
# tenants, so turning billing on never locks anyone out. Read via raw process.env.
# BILLING_ENFORCE_GATE="false"
