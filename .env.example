# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string (pooled connection recommended for serverless).
# Get it from https://console.neon.tech -> your project -> Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth — generate a long random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL (used by the auth client).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Optional ──────────────────────────────────────────────────────────────────
# Email receipts via Resend. The `emailReceipt` server action always renders the
# receipt to text/HTML and is tenant-scoped; it SENDS only when RESEND_API_KEY is
# set. Unset = the action returns `email_not_configured` and the UI shows a clear
# "not enabled yet" notice (the app/build work unchanged). To enable:
#   1. Create an API key at https://resend.com -> API Keys.
#   2. Set RESEND_API_KEY here and in Vercel (Production + Preview).
#   3. (Recommended for production) verify a sending domain at
#      https://resend.com -> Domains and set RECEIPT_FROM_EMAIL to an address on
#      it. If RECEIPT_FROM_EMAIL is unset, sends use Resend's onboarding sender
#      (onboarding@resend.dev), which only delivers to your own account's email.
# RESEND_API_KEY="re_..."
# RECEIPT_FROM_EMAIL="receipts@yourdomain.com"

# Upstash Redis — shared, persistent store for Better Auth's rate limiter (and a
# session cache). When BOTH are set, auth rate-limits sign-in/sign-up across all
# Vercel instances and survives cold starts; when unset, it falls back to
# per-instance in-memory limiting (fine for local dev). Create a free database at
# https://console.upstash.com -> Redis -> copy the REST URL + token, and set both
# in Vercel (Production + Preview) too.
# UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"
