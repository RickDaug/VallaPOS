# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string (pooled connection recommended for serverless).
# Get it from https://console.neon.tech -> your project -> Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth — generate a long random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL (used by the auth client).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
